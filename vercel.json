{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(index.html|admin.html|qrs.html|admin-profile.html|leaderboard.html)",
      "dest": "/public/$1"
    },
    {
      "src": "/qr_samples/(.*)",
      "dest": "/qr_samples/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
